<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{B3C3A2E4-7F1D-4D3A-9A1A-5E4F1A2B3C4D}</ProjectGuid>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <RootNamespace>VSFilterText</RootNamespace>
    <AssemblyName>VSFilterText</AssemblyName>

    <!-- VSIX packaging — VSSDKBuildToolsAutoSetup auto-imports Microsoft.VsSDK.targets from
         the BuildTools package and wires CreateVsixContainer into the build. No manual Import
         or custom AfterBuild targets needed. -->
    <VSSDKBuildToolsAutoSetup>true</VSSDKBuildToolsAutoSetup>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>true</IncludeDebugSymbolsInLocalVSIXDeployment>
  </PropertyGroup>

  <!-- F5 launches devenv under the Experimental hive. $(DevEnvDir) is set by MSBuild when
       building inside VS and points at the running devenv.exe. -->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <StartAction>Program</StartAction>
    <StartProgram>$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix Exp</StartArguments>
  </PropertyGroup>

  <ItemGroup>
    <!-- Tells the VS project system this is a VSIX project (enables VSIX-specific UI). -->
    <ProjectCapability Include="CreateVsixContainer" />
  </ItemGroup>

  <ItemGroup>
    <!-- 18.5.x build tools ship with VS 2026 and handle auto-setup correctly. -->
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="18.5.*" PrivateAssets="all" />
    <!-- VS SDK API assemblies; 17.14.x is still the current stable API surface for VS 18. -->
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.14.*" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Design" />
  </ItemGroup>

  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
  </ItemGroup>

  <ItemGroup>
    <VSCTCompile Include="Commands\VSFilterTextPackage.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>

  <ItemGroup>
    <Page Update="Editor\FilterQueryMargin.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>

</Project>
